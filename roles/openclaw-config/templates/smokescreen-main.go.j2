// Custom Smokescreen entrypoint for non-TLS deployments.
// The upstream main.go uses defaultRoleFromRequest, which extracts the ACL role
// from the client's TLS certificate CommonName. Since this deployment uses plain
// HTTP proxy traffic (HTTP_PROXY=http://openclaw-egress:4750), no client cert is
// ever presented, and all requests would be rejected.
//
// This entrypoint returns a static "default" role for all requests, which maps to
// the "default" policy in the ACL config (smokescreen-acl.yaml).
//
// Managed by Ansible — manual edits will be overwritten on next deploy.

package main

import (
	"net/http"

	"github.com/stripe/smokescreen/cmd"
	"github.com/stripe/smokescreen/pkg/smokescreen"
)

func main() {
	conf, err := cmd.NewConfiguration(nil, nil)
	if err != nil {
		panic(err)
	}
	conf.RoleFromRequest = func(req *http.Request) (string, error) {
		return "default", nil
	}
	if err := smokescreen.StartWithConfig(conf, nil); err != nil {
		panic(err)
	}
}
