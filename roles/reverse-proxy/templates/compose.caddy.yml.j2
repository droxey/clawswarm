services:
  caddy:
    image: caddy:{{ caddy_version }}
    container_name: openclaw-caddy
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy-data:/data
      - caddy-config:/config
    networks:
      - egress-net
      - proxy-net
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    security_opt:
      - no-new-privileges:true
    restart: unless-stopped

networks:
  proxy-net:
    external: true
    name: openclaw_proxy-net
  egress-net:
    external: true
    name: openclaw_egress-net

volumes:
  caddy-data:
  caddy-config:
