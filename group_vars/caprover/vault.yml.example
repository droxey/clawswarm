---
# CapRover Swarm Secrets — COPY THIS FILE TO vault.yml AND ENCRYPT
# cp vault.yml.example vault.yml
# ansible-vault encrypt vault.yml

# CapRover captain password (REQUIRED — change from default)
# Generate: openssl rand -base64 24
caprover_captain_password: ""

# Grafana admin password (REQUIRED if grafana enabled)
# Generate: openssl rand -base64 24
caprover_grafana_admin_password: ""

# code-server password (REQUIRED if code-server enabled)
# Generate: openssl rand -base64 24
caprover_codeserver_password: ""

# Docker Swarm join token (auto-generated during setup)
# caprover_swarm_join_token: ""
